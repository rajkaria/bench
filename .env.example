# =============================================================================
# Bench v2 — Environment Variables
# =============================================================================
# Copy to .env and fill in values. See API key acquisition checklist in README.

# --- Attestor ---
ATTESTOR_PRIVATE_KEY=           # secp256k1 private key (hex, no 0x prefix). Generated via `pnpm run generate-keypair`
ATTESTOR_ADDRESS=               # Ethereum address derived from the above key

# --- Database ---
DATABASE_URL=postgresql://bench:bench@localhost:5432/bench
REDIS_URL=redis://localhost:6379

# --- X Layer ---
XLAYER_RPC_URL=https://rpc.xlayer.tech
XLAYER_TESTNET_RPC_URL=https://testrpc.xlayer.tech
BENCH_REGISTRY_ADDRESS=         # Deployed BenchRegistry.sol address

# --- Tier 1: Universal EVM Aggregators ---
OKX_API_KEY=                    # https://www.okx.com/web3/build/docs/devportal/introduction
OKX_SECRET_KEY=                 # OKX API secret
OKX_PASSPHRASE=                 # OKX API passphrase
OKX_PROJECT_ID=                 # OKX project ID

ONEINCH_API_KEY=                # https://portal.1inch.dev — free tier: 1 req/sec

# 0x — DEFERRED (paid ~$50/mo, see DO_LATER.md)
# ZEROX_API_KEY=

VELORA_API_KEY=                 # https://app.paraswap.io — may not be needed for quotes

ODOS_API_KEY=                   # https://dashboard.odos.xyz — free tier

# KyberSwap — no key needed (public API)
# CoW Swap — no key needed (public API)

# Bebop — DEFERRED (partner key via Discord, see DO_LATER.md)
# BEBOP_API_KEY=

# Uniswap AI — verify access method from hackathon partners
UNISWAP_AI_API_KEY=

# OpenOcean — no key needed (public API)

# --- Tier 2: Solana ---
# Jupiter — no key needed (public API)
# Titan — DEFERRED (unverified API, see DO_LATER.md)

# --- Tier 3: Cross-Chain ---
LIFI_API_KEY=                   # https://li.fi — optional, higher rate limits with key
SQUID_INTEGRATOR_ID=            # https://docs.squidrouter.com — free integrator ID
RANGO_API_KEY=                  # https://rango.exchange — free tier

# --- API Server ---
PORT=3001
API_BASE_URL=http://localhost:3001

# --- Explorer ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_EXPLORER_URL=http://localhost:3000
BENCH_API_URL=http://localhost:3001  # Server-side API URL for Explorer (set to Railway URL in prod)
