{
  "name": "@bench/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pg": "^8.16.0",
    "ioredis": "^5.6.0",
    "@bench/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/pg": "^8.15.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}
